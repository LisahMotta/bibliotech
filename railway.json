{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd bibliotech/backend/backend && npm install && cd ../../../frontend && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "node bibliotech/backend/backend/server.js",
    "healthcheckPath": "/api",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
